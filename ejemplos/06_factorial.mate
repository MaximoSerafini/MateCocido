// Calcula el factorial de un número usando un bucle.
// Demuestra la EJECUCIÓN real: che(...) imprime los resultados.
mate Cocido {
    arrancar() {
        cebar entero n = 5;
        cebar entero factorial = 1;
        cebar entero i = 1;

        mientras (i <= n) {
            factorial = factorial * i;
            i = i + 1;
        }

        che("El factorial de:");
        che(n);
        che("es:");
        che(factorial);
    }
}
